{
  "name": "gluuh-tpv",
  "version": "0.0.0",
  "private": true,
  "description": "Plataforma TPV de hostelería (web + Windows + Android/iOS + backend). Monorepo.",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "core:demo": "pnpm --filter @gluuh/core demo",
    "core:test": "pnpm --filter @gluuh/core test"
  },
  "devDependencies": {
    "pg": "^8.21.0",
    "turbo": "^2.9.18",
    "typescript": "^6.0.3"
  }
}
