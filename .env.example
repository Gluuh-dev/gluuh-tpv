# =============================================================================
#  Gluuh — variables de entorno (PLANTILLA)
# =============================================================================
#  ⚠️  Este archivo (.env.example) SÍ se sube al repositorio. NO pongas aquí
#      ningún valor real ni contraseña — solo marcadores de posición.
#
#  Para usar valores reales: copia este archivo a `.env` (y, por app, a
#  `apps/web/.env.local` y `apps/api/.env`). Esos SÍ están en .gitignore.
#
#  Las contraseñas de cuentas (Gmail, GitHub, banco…) NO van en ningún .env:
#  guárdalas en un gestor de contraseñas (Bitwarden). Ver docs/15.
# =============================================================================

# --- Supabase (cliente / web) -------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://<ref-del-proyecto>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxx
# Solo servidor (motor fiscal/admin) — NUNCA en el cliente:
SUPABASE_SERVICE_ROLE_KEY=

# --- Base de datos (Postgres de Supabase) ------------------------------------
# Pooler en modo transacción (app):
DATABASE_URL="postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Pooler en modo sesión (migraciones):
DIRECT_URL="postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# --- API ----------------------------------------------------------------------
PORT=3001
JWT_SECRET=

# --- Pagos (Stripe) — ver docs/08 --------------------------------------------
STRIPE_SECRET_KEY=sk_test_xxxxxxxx

# --- AEAT VERIFACTU — ver docs/07 --------------------------------------------
AEAT_ENTORNO=pruebas
AEAT_CERT_PATH=./secrets/certificado.p12
AEAT_CERT_PASSWORD=
