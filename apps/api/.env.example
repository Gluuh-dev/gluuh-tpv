# Copia este archivo a .env y rellena los valores.

# Servidor
PORT=3001

# Base de datos (PostgreSQL) — ver apps/api/db/schema.sql
DATABASE_URL=postgresql://servio_app:CAMBIAME@localhost:5432/servio

# Auth (Supabase / JWT) — ver docs/05 §11
JWT_SECRET=CAMBIAME

# Pagos (Stripe) — ver docs/08
STRIPE_SECRET_KEY=sk_test_...

# AEAT VERIFACTU — entorno (pruebas | produccion) y certificado — ver docs/07
AEAT_ENTORNO=pruebas
AEAT_CERT_PATH=./secrets/certificado.p12
