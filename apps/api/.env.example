# Plantilla de entorno de la API (NestJS). SE SUBE al repo: solo placeholders.
# Copia a apps/api/.env (ignorado por git) y pon los valores reales.

# Servidor
PORT=3001

# Supabase
SUPABASE_URL=https://<ref-del-proyecto>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=        # SOLO servidor — desde Supabase > Settings > API

# Base de datos (Postgres de Supabase) — ver apps/api/db/schema.sql
DATABASE_URL="postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.<ref>:[YOUR-PASSWORD]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# Auth (JWT) — ver docs/05 §11
JWT_SECRET=

# Pagos (Stripe) — ver docs/08
STRIPE_SECRET_KEY=sk_test_...

# AEAT VERIFACTU — ver docs/07
AEAT_ENTORNO=pruebas
AEAT_CERT_PATH=./secrets/certificado.p12
AEAT_CERT_PASSWORD=
