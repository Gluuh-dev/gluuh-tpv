{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Servio TPV",
  "version": "0.0.0",
  "identifier": "com.servio.tpv",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Servio TPV",
        "width": 1280,
        "height": 800,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
